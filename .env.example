# PostgreSQL credentials — used by both the db service and backend
POSTGRES_USER=huskyreads
POSTGRES_PASSWORD=changeme
POSTGRES_DB=huskyreads

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret

# Optional: comma-separated extra origins to allow in CORS (leave blank for defaults)
CORS_ORIGINS=
